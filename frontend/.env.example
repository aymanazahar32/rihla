# Copy to .env and fill in. Restart `npm run dev` after changes.

# Supabase: Dashboard → Project Settings → API
# Project URL:
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use the "anon" / "public" key (JWT, usually a long string starting with eyJ...).
# If login fails, double-check you did not paste the "service_role" secret here.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Google Maps (ride maps / picker)
VITE_GOOGLE_MAPS_API_KEY=
